# === SYSTEM CONFIGURATION ===
HUMAN_REVIEW_MODE=false
HUMAN_OPERATOR_EMAIL=
HUMAN_SLACK_WEBHOOK=
SALES_ACTIVATION_THRESHOLD=5
SECURITY_BLOCK_ON_HIGH=true
