# ═══════════════════════════════════════════════════════════════
# AIBE v2.0 — Environment Variables
# Copy to .env and fill in all required values
# ═══════════════════════════════════════════════════════════════

# === LLM ROUTING ===
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aibe-v2

# === MEMORY (OpenViking) ===
OPENVIKING_CONNECTION_STRING=
OPENVIKING_API_KEY=

# === DATABASES ===
DATABASE_URL=postgresql+asyncpg://aibe:changeme@postgres:5432/aibe
DATABASE_SYNC_URL=postgresql://aibe:changeme@postgres:5432/aibe
POSTGRES_USER=aibe
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aibe

# === REDIS ===
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_CELERY_URL=redis://redis:6379/2

# === NATS ===
NATS_URL=nats://nats:4222
NATS_CLUSTER_NAME=aibe-cluster

# === CLICKHOUSE ===
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=aibe
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DATABASE=aibe_analytics

# === HASHICORP VAULT ===
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=changeme
VAULT_MOUNT_POINT=secret

# === BROWSER AUTOMATION ===
LIGHTPANDA_API_URL=http://lightpanda-pool:8080
LIGHTPANDA_POOL_SIZE=3
LIGHTPANDA_MAX_POOL_SIZE=10
BRIGHT_DATA_PROXY_URL=
BRIGHT_DATA_ZONE=

# === CLOUD INFRASTRUCTURE ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=changeme
TERRAFORM_CLOUD_TOKEN=

# === MONITORING ===
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
PROMETHEUS_PUSHGATEWAY_URL=http://prometheus:9091

